generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String
  role          String          @default("member")
  createdAt     DateTime        @default(now())
  projects      ProjectMember[]
  notifications Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  linkUrl   String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Category {
  id       String     @id @default(cuid())
  name     String
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  sops     Sop[]
}

model Sop {
  id                    String    @id @default(cuid())
  title                 String    @default("Untitled SOP")
  purpose               String    @default("")
  steps                 String    @default("")
  rolesResponsibilities String    @default("")
  decisionPoints        String    @default("")
  toolsSystems          String    @default("")
  loomVideoUrl          String    @default("")
  categoryId            String?
  category              Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Person {
  id                 String             @id @default(cuid())
  name               String
  email              String?            @unique
  title              String             @default("")
  location           String             @default("")
  managerId          String?
  manager            Person?            @relation("OrgTree", fields: [managerId], references: [id], onDelete: SetNull)
  reports            Person[]           @relation("OrgTree")
  photo              String?
  goals              String             @default("")
  hobbies            String             @default("")
  interests          String             @default("")
  vacationAllowance  Int                @default(10)
  sickAllowance      Int                @default(5)
  taskCollaborations TaskCollaborator[]
  ptoRequests        PtoRequest[]       @relation("PtoRequests")
  ptoReviews         PtoRequest[]       @relation("PtoReviews")
}

model Project {
  id           String          @id @default(cuid())
  name         String
  description  String          @default("")
  status       String          @default("On Track")
  notes        String          @default("")
  sectionOrder String          @default("[]")
  columnConfig String          @default("{}") // JSON: { hiddenColumns: string[] }
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tasks        Task[]
  members      ProjectMember[]
  customFields CustomField[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Task {
  id            String             @id @default(cuid())
  projectId     String
  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId      String?
  parent        Task?              @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks      Task[]             @relation("Subtasks")
  title         String             @default("Untitled")
  description   String             @default("")
  dueDate       String?
  priority      String             @default("medium")
  status        String             @default("On Track")
  notes         String             @default("")
  completed     Boolean            @default(false)
  createdAt     DateTime           @default(now())
  collaborators    TaskCollaborator[]
  customFieldValues TaskCustomFieldValue[]
}

model TaskCollaborator {
  id       String @id @default(cuid())
  taskId   String
  personId String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([taskId, personId])
}

model PtoRequest {
  id         String   @id @default(cuid())
  personId   String
  person     Person   @relation("PtoRequests", fields: [personId], references: [id], onDelete: Cascade)
  type       String   @default("vacation")
  startDate  DateTime
  endDate    DateTime
  days       Float
  note       String   @default("")
  status     String   @default("pending")
  reviewerId String?
  reviewer   Person?  @relation("PtoReviews", fields: [reviewerId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CustomField {
  id        String                 @id @default(cuid())
  projectId String
  project   Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  type      String                 @default("text") // "text", "single-select", "multi-select"
  options   String                 @default("[]") // JSON array of options for select types
  position  Int                    @default(0)
  createdAt DateTime               @default(now())
  values    TaskCustomFieldValue[]
}

model TaskCustomFieldValue {
  id            String      @id @default(cuid())
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  value         String      @default("") // text value or JSON array for multi-select

  @@unique([taskId, customFieldId])
}

model ContentDocument {
  id         String   @id @default(cuid())
  title      String   @default("Untitled")
  categoryId String
  content    String   @default("")
  updatedAt  DateTime @updatedAt
}
