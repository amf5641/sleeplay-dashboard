generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  passwordHash       String
  role               String          @default("member")
  mustChangePassword Boolean         @default(false)
  failedAttempts     Int             @default(0)
  lockedUntil        DateTime?
  totpSecret         String?
  totpEnabled        Boolean         @default(false)
  totpRecoveryCodes  String          @default("[]")
  createdAt          DateTime        @default(now())
  lastLoginAt        DateTime?
  projects           ProjectMember[]
  notifications      Notification[]
  comments           TaskComment[]
  activityEvents     ActivityEvent[] @relation("ActivityEvents")
  createdProjects    Project[]       @relation("ProjectCreator")
  createdTasks       Task[]          @relation("TaskCreator")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  linkUrl   String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Category {
  id       String     @id @default(cuid())
  name     String
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  sops     Sop[]
}

model Sop {
  id                    String    @id @default(cuid())
  title                 String    @default("Untitled SOP")
  purpose               String    @default("")
  steps                 String    @default("")
  rolesResponsibilities String    @default("")
  decisionPoints        String    @default("")
  toolsSystems          String    @default("")
  loomVideoUrl          String    @default("")
  categoryId            String?
  category              Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Person {
  id                 String             @id @default(cuid())
  name               String
  email              String?            @unique
  title              String             @default("")
  location           String             @default("")
  managerId          String?
  manager            Person?            @relation("OrgTree", fields: [managerId], references: [id], onDelete: SetNull)
  reports            Person[]           @relation("OrgTree")
  photo              String?
  goals              String             @default("")
  hobbies            String             @default("")
  interests          String             @default("")
  responsibilities   String             @default("")
  skills             String             @default("")
  startDate          DateTime?
  slack              String             @default("")
  phone              String             @default("")
  vacationAllowance  Float              @default(10)
  sickAllowance      Float              @default(5)
  taskCollaborations TaskCollaborator[]
  ptoRequests        PtoRequest[]       @relation("PtoRequests")
  ptoReviews         PtoRequest[]       @relation("PtoReviews")
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#664FA6")
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id           String          @id @default(cuid())
  name         String
  description  String          @default("")
  status       String          @default("On Track")
  notes        String          @default("")
  color        String          @default("#664FA6")
  sectionOrder String          @default("[]")
  columnConfig String          @default("{}") // JSON: { hiddenColumns: string[] }
  departmentId String?
  department   Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?           @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tasks          Task[]
  members        ProjectMember[]
  customFields   CustomField[]
  activityEvents ActivityEvent[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Task {
  id            String             @id @default(cuid())
  projectId     String
  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId      String?
  parent        Task?              @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks      Task[]             @relation("Subtasks")
  title         String             @default("Untitled")
  description   String             @default("")
  dueDate       String?
  priority      String             @default("medium")
  status        String             @default("On Track")
  notes         String             @default("")
  completed     Boolean            @default(false)
  repeatFreq    String?            // "daily", "weekly", "monthly", "yearly"
  repeatDay     Int?               // day of week (0-6) for weekly, day of month for monthly
  createdById   String?
  createdBy     User?              @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  collaborators    TaskCollaborator[]
  customFieldValues TaskCustomFieldValue[]
  attachments      TaskAttachment[]
  comments         TaskComment[]
  dependsOn        TaskDependency[] @relation("DependsOn")
  blocks           TaskDependency[] @relation("Blocks")
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name      String
  url       String
  createdAt DateTime @default(now())
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskCollaborator {
  id       String @id @default(cuid())
  taskId   String
  personId String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([taskId, personId])
}

model PtoRequest {
  id         String   @id @default(cuid())
  personId   String
  person     Person   @relation("PtoRequests", fields: [personId], references: [id], onDelete: Cascade)
  type       String   @default("vacation")
  startDate  DateTime
  endDate    DateTime
  days       Float
  note       String   @default("")
  status     String   @default("pending")
  reviewerId String?
  reviewer   Person?  @relation("PtoReviews", fields: [reviewerId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CustomField {
  id        String                 @id @default(cuid())
  projectId String
  project   Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  type      String                 @default("text") // "text", "single-select", "multi-select"
  options   String                 @default("[]") // JSON array of options for select types
  position  Int                    @default(0)
  createdAt DateTime               @default(now())
  values    TaskCustomFieldValue[]
}

model TaskCustomFieldValue {
  id            String      @id @default(cuid())
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  value         String      @default("") // text value or JSON array for multi-select

  @@unique([taskId, customFieldId])
}

model ContentCategory {
  id       String            @id @default(cuid())
  name     String
  parentId String?
  parent   ContentCategory?  @relation("ContentCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ContentCategory[] @relation("ContentCategoryTree")
  docs     ContentDocument[]
}

model ContentDocument {
  id         String           @id @default(cuid())
  title      String           @default("Untitled")
  categoryId String?
  category   ContentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  content    String           @default("")
  updatedAt  DateTime         @updatedAt
}

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("ActivityEvents", fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  action    String
  detail    String   @default("")
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([createdAt])
}

model TaskDependency {
  id              String @id @default(cuid())
  taskId          String
  blockedByTaskId String
  task            Task   @relation("DependsOn", fields: [taskId], references: [id], onDelete: Cascade)
  blockedByTask   Task   @relation("Blocks", fields: [blockedByTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, blockedByTaskId])
}

model ProjectTemplate {
  id          String                   @id @default(cuid())
  name        String
  description String                   @default("")
  sections    ProjectTemplateSection[]
  createdAt   DateTime                 @default(now())
}

model ProjectTemplateSection {
  id         String                @id @default(cuid())
  templateId String
  template   ProjectTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  position   Int                   @default(0)
  tasks      ProjectTemplateTask[]
}

model ProjectTemplateTask {
  id        String                 @id @default(cuid())
  sectionId String
  section   ProjectTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title     String
  priority  String                 @default("medium")
  position  Int                    @default(0)
}
